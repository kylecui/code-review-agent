{
  "$schema": "https://json.schemastore.org/sarif-2.1.0.json",
  "version": "2.1.0",
  "runs": [
    {
      "tool": {
        "driver": {
          "name": "gitleaks",
          "rules": [
            {
              "id": "gitleaks-rule-1",
              "properties": {
                "category": "security.secret-detection",
                "precision": "very-high",
                "cwe": ["CWE-798"]
              }
            }
          ]
        }
      },
      "results": [
        {
          "ruleId": "gitleaks-rule-1",
          "ruleIndex": 0,
          "level": "error",
          "message": {
            "text": "Hardcoded secret found"
          },
          "partialFingerprints": {
            "primaryLocationLineHash": "gitleaks-fp-123"
          },
          "locations": [
            {
              "physicalLocation": {
                "artifactLocation": {
                  "uri": "app/config.py"
                },
                "region": {
                  "startLine": 14,
                  "endLine": 14,
                  "snippet": {
                    "text": "API_KEY = 'secret-value'"
                  }
                }
              }
            }
          ]
        }
      ]
    }
  ]
}
