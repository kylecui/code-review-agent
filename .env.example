# Database
AGENT_REVIEW_DATABASE_URL=sqlite+aiosqlite:///./dev.db

# GitHub App
AGENT_REVIEW_GITHUB_APP_ID=0
AGENT_REVIEW_GITHUB_PRIVATE_KEY=""
AGENT_REVIEW_GITHUB_WEBHOOK_SECRET=""

# LLM (via litellm)
AGENT_REVIEW_LLM_CLASSIFY_MODEL=gpt-4o-mini
AGENT_REVIEW_LLM_SYNTHESIZE_MODEL=gpt-4o
AGENT_REVIEW_LLM_FALLBACK_MODEL=gpt-4o-mini
AGENT_REVIEW_LLM_MAX_TOKENS=4096
AGENT_REVIEW_LLM_COST_BUDGET_PER_RUN_CENTS=50

# Collectors
AGENT_REVIEW_SONAR_HOST_URL=
AGENT_REVIEW_SONAR_TOKEN=
AGENT_REVIEW_SEMGREP_APP_TOKEN=
AGENT_REVIEW_SEMGREP_MODE=app

# Limits
AGENT_REVIEW_MAX_INLINE_COMMENTS=25
AGENT_REVIEW_MAX_DIFF_LINES=10000

# Policy
AGENT_REVIEW_POLICY_DIR=./policies

# Observability
AGENT_REVIEW_LOG_LEVEL=INFO
AGENT_REVIEW_LOG_FORMAT=console
